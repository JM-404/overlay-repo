# =============================================================================
# Xiaoling voice assistant — environment template
# Copy this file to `.env` on the server, fill in real values, and keep it OUT
# of git (it's in .gitignore).
# =============================================================================

# ------------------------------ Server / runtime ------------------------------
LOG_PATH=/tmp/ten_agent
LOG_STDOUT=true
GRAPH_DESIGNER_SERVER_PORT=49483
SERVER_PORT=8080
WORKERS_MAX=100
WORKER_QUIT_TIMEOUT_SECONDS=60

# ------------------------------ Frontend --------------------------------------
AGENT_SERVER_URL=http://localhost:8080
TEN_DEV_SERVER_URL=http://localhost:49483
NEXT_PUBLIC_EDIT_GRAPH_MODE=true

# ==============================================================================
# AI vendor credentials
# ==============================================================================
# This project CAN run with either OpenAI/Deepgram (overseas) or with domestic
# vendors (Aliyun / Moonshot / DeepSeek / Bytedance / Xfyun / Minimax / etc.).
#
# For deployment on a Chinese cloud (Aliyun/Tencent/Huawei/Volcengine), OpenAI
# and Deepgram are UNREACHABLE without an outbound proxy. Use a domestic vendor.
#
# Fill in ONLY the vendors you actually use; leave the rest empty.
# See DEPLOYMENT.md for which extension maps to which env vars.
# ==============================================================================

# --- LLM (pick one) -----------------------------------------------------------
# OpenAI (overseas only, or through outbound proxy)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-2024-11-20
OPENAI_PROXY_URL=

# Moonshot (Kimi) — OpenAI-compatible, Chinese, usable out of the box from ECS
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# DeepSeek — also OpenAI-compatible
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Aliyun DashScope (Qwen)
QWEN_API_KEY=

# Zhipu GLM
GLM_API_KEY=

# --- STT ----------------------------------------------------------------------
# Deepgram (overseas)
DEEPGRAM_API_KEY=

# Aliyun ASR
ALIYUN_ASR_APPKEY=
ALIYUN_ASR_TOKEN=

# Tencent ASR
TENCENT_ASR_APP_ID=
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=

# Xfyun (讯飞)
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# Bytedance (火山 Volcengine) ASR
BYTEDANCE_ASR_APPID=
BYTEDANCE_ASR_TOKEN=
BYTEDANCE_ASR_CLUSTER=

# --- TTS ----------------------------------------------------------------------
# OpenAI TTS (overseas) — reuses OPENAI_API_KEY
# ElevenLabs (overseas)
ELEVENLABS_TTS_KEY=

# Minimax TTS
MINIMAX_TTS_API_KEY=
MINIMAX_TTS_GROUP_ID=

# Bytedance TTS
BYTEDANCE_TTS_APPID=
BYTEDANCE_TTS_TOKEN=

# Aliyun Cosy TTS
COSY_TTS_KEY=

# --- Optional tools -----------------------------------------------------------
WEATHERAPI_API_KEY=

# --- RTC (not needed for websocket-example, only for voice-assistant-live2d) --
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
